flowchart TB
    IN(["Query from Forge (MCP)"]) --> DQ

    subgraph CRA["Central Research Agent — ADK SequentialAgent"]
        direction TB
        DQ["1 · decompose_agent<br/>sub_questions"] --> PL["2 · plan_agent<br/>consultation plan"]
        PL --> LOOP

        subgraph LOOP["consult_loop — ADK LoopAgent, max 4 iterations"]
            direction TB
            CA["3 · consult_agent<br/>calls LOB tool"] --> RF["4 · record_finding<br/>(deterministic)"]
            RF --> EA["5a · evaluate_agent<br/>LoopStatus"]
            EA --> EC{"5b · exit_checker<br/>(deterministic)"}
            EC -->|"refine"| CA
        end

        LOOP -->|"done OR no-progress"| RC["6 · reconcile_agent<br/>cross-round conflicts"]
        RC --> SY["7 · synthesis_agent<br/>cited final answer"]
    end

    CA -.->|"usp_research(...)"| USP[["USP LOB Agent<br/>external · MCP :8001 / A2A :8002"]]
    USP -.->|"finding + evidence"| CA

    SY --> OUT(["final_answer → Forge"])

    classDef llm fill:#EAF2FB,stroke:#1B4F9C,color:#1B4F9C
    classDef det fill:#F3F3F3,stroke:#666,color:#333
    classDef ext fill:#E6F4F1,stroke:#0F766E,stroke-dasharray: 4 3,color:#0F766E
    classDef io fill:#FFF,stroke:#999,color:#333

    class DQ,PL,CA,EA,RC,SY llm
    class RF,EC det
    class USP ext
    class IN,OUT io
